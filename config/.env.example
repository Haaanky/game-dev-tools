# Steam game library extractor
STEAM_API_KEY=       # https://steamcommunity.com/dev/apikey
STEAM_ID=            # 64-bit Steam ID, e.g. 76561198015238798

# PSN game/trophy extractor
# How to get your NPSSO token:
#   1. Log in at https://www.playstation.com
#   2. Open: https://ca.account.sony.com/api/v1/ssocookie
#   3. Copy the "npsso" value from the JSON response.
NPSSO=               # PSN NPSSO cookie token
PSN_USERNAME=        # PSN Online ID to look up (optional — defaults to own profile)

# Cloud API keys — fill in the services you want to use
OPENAI_API_KEY=
HUGGING_FACE=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=

# Local server overrides (optional — only needed if you change default ports)
# LOCAL_SPRITE_URL=http://localhost:7860/sdapi/v1/txt2img
# LOCAL_SFX_URL=http://localhost:8080/generate/sfx
# LOCAL_MUSIC_URL=http://localhost:8080/generate/music

# Commands to auto-start local servers (optional)
# LOCAL_SPRITE_START_CMD=python /opt/sd-webui/launch.py --nowebui
# LOCAL_SFX_START_CMD=python src/servers/local_audio_server.py
# LOCAL_MUSIC_START_CMD=python src/servers/local_audio_server.py

# Output directory override (default: $PWD/assets/generated)
# ASSET_OUTPUT_DIR=/path/to/project/assets/generated

# Set to any value to skip cloud and always use local
# FORCE_LOCAL_AI=1
